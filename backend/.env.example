# Database
DATABASE_URL="postgresql://logistique:logistique_pass@localhost:5432/logistique_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Logistique D3 <your-email@gmail.com>"

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
