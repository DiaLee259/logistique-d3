{
  "version": 2,
  "buildCommand": "npm install && npx prisma migrate deploy && npx prisma generate && npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30,
      "includeFiles": "dist/**,node_modules/.prisma/**,node_modules/@prisma/client/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
